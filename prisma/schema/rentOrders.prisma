model RentOrders {
    order_id String @id @default(uuid())
    quantity Int
    total_amount Decimal
    pickup_date DateTime @db.Date
    return_date DateTime @db.Date
    returned_on DateTime? @db.Date
    order_status OrderStatus @default(PLACED)       
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    customer_id String 
    customer User @relation(fields: [customer_id], references: [user_id])

    item_id String 
    item GearItems @relation(fields: [item_id], references: [item_id])
    
    review Reviews?
    payment Payment[]


    @@map("orders")



}

