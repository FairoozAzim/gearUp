model Payment {
    payment_id      String  @id @default(uuid())
    transaction_id  String @unique
    amount          Decimal @db.Decimal(10, 2)
    method          String
    provider        PaymentProvider @default(SSLCommerz)
    status          PaymentStatus   @default(PENDING)
    paidAt          DateTime?
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt

    order_id String
    order    RentOrders @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

    @@map("payments")
}