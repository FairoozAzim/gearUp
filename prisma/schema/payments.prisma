model Payment {
    transaction_id String @id @default(uuid())
    amount Decimal
    method String
    provider PaymentProvider @default(SSLCommerz)
    status PaymentStatus @default(PENDING)
    paidAt DateTime
    createdAt DateTime @default(now())

    order_id String
    order RentOrders @relation(fields: [order_id], references: [order_id])

    @@map("payments")


}


